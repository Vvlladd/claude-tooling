# Copy to `.env` and fill in. Bun auto-loads `.env` from the working dir.

# Proxy listen port
PORT=8787

# --- Anthropic ---
# Upstream base URL (change only for testing against a staging endpoint)
ANTHROPIC_UPSTREAM=https://api.anthropic.com

# Fallback API key used ONLY when the incoming request omits x-api-key.
# In normal Claude Code usage the client sends its own key, so this can stay empty.
ANTHROPIC_API_KEY=

# --- LM Studio (or any OpenAI-compatible local server) ---
# OpenAI-compatible endpoint base (no trailing slash)
LMSTUDIO_URL=http://127.0.0.1:1234

# Default model name sent to LM Studio for haiku-routed requests.
# Override per-request by using `local/<model-id>` as the model in the Claude Code request.
LMSTUDIO_MODEL=qwen2.5-coder-32b-instruct

# LM Studio accepts any bearer token value
LMSTUDIO_KEY=lm-studio

# --- Routing ---
# Set to 1 to route any incoming model name containing "haiku" to LM Studio.
# Useful for shipping compaction / title generation / background tasks to local.
ROUTE_HAIKU_LOCAL=0

# --- Observability ---
# Set to 1 to log one line per request (model, target, status, duration).
DEBUG=0
